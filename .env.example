# Backend environment variables for Railway/Render/local production
SPRING_PROFILES_ACTIVE=prod
PORT=8080

# Use Railway's public PostgreSQL values to build a JDBC URL:
# jdbc:postgresql://<HOST>:<PORT>/<DATABASE>?sslmode=require
DB_URL=jdbc:postgresql://<HOST>:<PORT>/<DATABASE>?sslmode=require
DB_USERNAME=<DB_USERNAME>
DB_PASSWORD=<DB_PASSWORD>

JWT_SECRET=<strong_32_plus_character_secret>
BASE_URL=https://your-backend.up.railway.app
FRONTEND_URL=https://your-frontend.vercel.app
APP_CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

PESAPAL_CONSUMER_KEY=<pesapal_consumer_key>
PESAPAL_CONSUMER_SECRET=<pesapal_consumer_secret>
PESAPAL_BASE_URL=https://cybqa.pesapal.com/pesapalv3
PESAPAL_IPN_URL=https://your-backend.up.railway.app/api/payments/webhook
PESAPAL_CALLBACK_URL=https://your-frontend.vercel.app/payment/callback
PESAPAL_REGISTRATION_FEE_AMOUNT=10000.0
PESAPAL_MONTHLY_SUBSCRIPTION_AMOUNT=5000.0
